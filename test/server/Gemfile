source "https://rubygems.org"

# Minimal Rails for ActionCable + a controller; ActiveRecord is never loaded.
gem "rails", "~> 8.0"
gem "puma"

# The library under test. Path-pinned to the local checkout so tests exercise
# the latest yrby (reliable delivery + causal-gap protection), not a
# published version. The ActionCable concern (Y::ActionCable::Sync) lives
# in the companion yrby-actioncable gem (same repo).
gem "yrby", path: "../../../yrby"
gem "yrby-actioncable", path: "../../../yrby"
